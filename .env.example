# NEXO AI — Environment Variables
# Copy this file to .env.local for local development.
# On Vercel: Project Settings → Environment Variables → add both keys.

# GitHub Marketplace Models token (used for Nexio, Spadec, Brainex, Craft)
# Get it from: https://github.com/marketplace/models -> "Get API key"
GITHUB_MODELS_TOKEN=your_github_models_token_here

# Groq API key (used for Galex 4.0)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
